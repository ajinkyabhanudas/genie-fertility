# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Server-side only (server/) — never exposed to the client bundle ---

# GEMINI_API_KEY: read only by server/index.ts. Never referenced by client code
# or vite.config.ts define() — that was the S3 vulnerability this phase fixed.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AUTH_TOKEN: single bearer token checked by server/auth.ts middleware on all
# /api/* routes. Interim single-tenant scheme (see DECISIONS.md / SP-2 spec) —
# no rotation process yet, structured so SSO can replace it later.
AUTH_TOKEN="MY_AUTH_TOKEN"

# DATABASE_URL: Postgres connection string for the audit log, source cache,
# generation cache, and document_chunks (pgvector) tables. Run `docker compose
# up` for a local instance matching this default.
DATABASE_URL="postgres://genie:genie_dev_only@localhost:5432/genie"

# PROXY_PORT: port the Express proxy listens on. Defaults to 8787.
PROXY_PORT="8787"
